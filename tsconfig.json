{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["agent/**/*", "storage/**/*", "compute/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "contracts", "web"]
}
